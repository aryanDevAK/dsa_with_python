# 3. Search and Transform Demo
def string_search_transform_demo():
    s = "  Python Programming Language  "
    trimmed = s.strip()
    upper = trimmed.upper()
    lower = trimmed.lower()
    has_prefix = trimmed.startswith("Py")
    has_suffix = trimmed.endswith("Language")
    contains_prog = "Programming" in trimmed
    first_index_g = trimmed.find("g")
    last_index_g = trimmed.rfind("g")
    missing_find = trimmed.find("Java")
    
    # Padding
    raw_num = "42"
    padded_left = raw_num.rjust(5, "0")
    padded_right = raw_num.ljust(5, "-")
    padded_center = "Title".center(15, "*")
    
    # Boolean Inspections
    is_numeric = "12345".isdigit()
    is_alphabetic = "Python".isalpha()
    is_space = "   ".isspace()

    # Case folding
    germ_word1 = "Strasse"
    germ_word2 = "Straße"
    unicode_match = germ_word1.casefold() == germ_word2.casefold()

    print(f"Trimmed: '{trimmed}'")
    print(f"Starts with 'Py'?: {has_prefix}")
    print(f"Contains 'Programming'?: {contains_prog}")
    print(f"First 'g' index: {first_index_g} | Last 'g' index: {last_index_g}")
    print(f"Padded left/right/center: '{padded_left}' | '{padded_right}' | '{padded_center}'")
    print(f"Boolean checks: digits={is_numeric}, alphas={is_alphabetic}, spaces={is_space}")
    print(f"Unicode case-folding match: {unicode_match}")

# 4. Split and Join Demo
def split_join_demo():
    csv_line = "apple,banana,orange,grape"
    fruits_list = csv_line.split(",")
    print(f"Splits List: {fruits_list}")
    spaced_string = " | ".join(fruits_list)
    print(f"Joined String: {spaced_string}")
    limited_split = csv_line.split(",", maxsplit=2)
    print(f"Limited Split (max 2): {limited_split}")

# 5. Concatenation Buffer Comparison
def compare_concatenations():
    iterations = 10_000
    s = ""
    for i in range(iterations):
        s += "a"
    list_accumulator = []
    for i in range(iterations):
        list_accumulator.append("a")
    list_str = "".join(list_accumulator)
    buffer = io.StringIO()
    for i in range(iterations):
        buffer.write("a")
    stringio_str = buffer.getvalue()
    buffer.close()
    print("Buffer comparison executed successfully.")


